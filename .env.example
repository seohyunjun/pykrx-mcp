# KRX 데이터광장(data.krx.co.kr) 계정 자격증명.
# pykrx>=1.2.8 은 아래 환경변수로 KRX에 로그인합니다. 설정하지 않으면
# 모든 KRX JSON 데이터 호출이 "LOGOUT" (HTTP 400) 으로 실패합니다.
#
# 사용법: 이 파일을 .env 로 복사한 뒤 실제 값으로 채우세요. (.env 는 git 무시됨)
#   cp .env.example .env
KRX_ID=your_krx_id
KRX_PW=your_krx_password

# --- 로깅 (선택) ---
# 로그는 항상 stderr 로 출력됩니다. 아래 LOG_FILE 을 지정하면 회전(rotating)
# 파일에도 함께 기록되어 로그가 영구적으로 쌓입니다.
# LOG_LEVEL: DEBUG / INFO / WARNING / ERROR (기본 INFO)
# LOG_FILE:  로그 파일 경로 (디렉터리는 자동 생성됨)
LOG_LEVEL=INFO
LOG_FILE=logs/pykrx-mcp.log
